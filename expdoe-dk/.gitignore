# Python build / runtime artifacts
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# Virtual envs
.venv/
venv/
env/

# IDE
.idea/
.vscode/

# OS
.DS_Store

# Allow example notebooks and pyproject.toml even though the parent
# repo's .gitignore excludes *.ipynb / *.json — these are part of the package.
!examples/*.ipynb
!pyproject.toml
